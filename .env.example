# 本地开发：复制为 .env.local
# 国内服务器 + docker compose：复制为 .env（与 docker-compose.yml 同级）
# Railway/Render：在面板「环境变量」里逐项填写
#
# 登录 Cookie 签名（生产必填，随机长字符串）
AUTH_SECRET=

# 首次部署时若 data/users.json 不存在，会用下面账号创建管理员（务必改掉默认密码）
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=

# 生产环境允许未登录用户读取热点列表（公开站点建议设为 1）
HOTSPOTS_PUBLIC=1

# OpenAI / OpenRouter 等（也可用管理后台写入 data/secrets.json，不推荐把密钥提交到 Git）
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openrouter/free

# 可选：定时同步热点（外部 Cron 调 GET /api/cron/sync-hotspots?secret=...）
# CRON_SECRET=
